{
  "name": "livetabs",
  "version": "1.0.3",
  "description": "A lightweight, interactive tab management library for web applications",
  "main": "dist/LiveTabs.js",
  "scripts": {
    "build": "tsc && terser dist/LiveTabs.js -o dist/LiveTabs.min.js -c -m",
    "start": "node dist/LiveTabs.js",
    "test": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davideticchiarelli01/LiveTabs.git"
  },
  "author": "davideticchiarelli01",
  "license": "MIT",
  "private": false,
  "keywords": [
    "tab",
    "tabs",
    "tab management",
    "drag and drop",
    "dynamic tabs",
    "web applications",
    "frontend",
    "UI",
    "JavaScript",
    "TypeScript",
    "AJAX"
  ],
  "devDependencies": {
    "terser": "^5.46.2",
    "typescript": "^4.0.0"
  },
  "files": [
    "dist/",
    "assets/images/",
    "src/"
  ]
}
